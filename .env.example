# Template for .env (gitignored). Copy to .env and fill in real values.
# Used to drive the Coolify deployment of Prophet (going-public plan §4).

# --- Coolify ---------------------------------------------------------------
# Base URL of the Coolify instance (no trailing slash), e.g. https://coolify.example.com
COOLIFY_BASE_URL=
# Coolify API token (Bearer). Create under: Keys & Tokens -> API tokens.
COOLIFY_API_TOKEN=
# Optional: target identifiers for API calls (filled once the app/server exist).
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_APP_UUID=

# --- Embedder (optional; hybrid retrieval) ---------------------------------
# OpenAI-compatible /v1/embeddings endpoint (TEI in production). Use 127.0.0.1,
# not localhost (JVM HttpClient resolves localhost to IPv6).
SLAYER_EMBED_URL=
SLAYER_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
SLAYER_EMBED_API_KEY=
