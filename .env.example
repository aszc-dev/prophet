# Template for .env (gitignored). Copy to .env and fill in real values.

# --- Embedder (demo/preview: local omlx, ADR-013) --------------------------
# OpenAI-compatible /v1/embeddings served by the local omlx server. Use 127.0.0.1,
# not localhost (JVM HttpClient resolves localhost to IPv6 ::1; omlx binds IPv4).
# Leave SLAYER_EMBED_URL empty to run inert (FTS + alias + graph, vector lane off).
SLAYER_EMBED_URL=http://127.0.0.1:10240
SLAYER_EMBED_MODEL=Qwen3-Embedding-0.6B-8bit
SLAYER_EMBED_API_KEY=

# --- MCP (optional) --------------------------------------------------------
# Bearer token for the HTTP transport; unused by the stdio demo path.
MCP_AUTH_TOKEN=

# --- Coolify (parked: future hosted deployment, ADR-013) -------------------
# COOLIFY_BASE_URL=
# COOLIFY_API_TOKEN=
# COOLIFY_PROJECT_UUID=
# COOLIFY_SERVER_UUID=
# COOLIFY_APP_UUID=
