# the note store — code-only repo (ADR-014): kb/ is built locally or
# on the deploy host from its source repo (slayerlabs/slayer), never committed here.
kb/

# derived index — rebuildable from kb/ (invariant #1), never source of truth.
# *.db also covers the derived telemetry.db mirror (ADR-011).
kb.db
*.db

# telemetry capture (append-only JSONL; path is operator-chosen via env)
telemetry*.jsonl

# clojure / tooling
.cpcache/
.clj-kondo/.cache/
target/

# local test scaffolding (a throwaway source git repo for manual ingest)
/fixtures/

# generated Hugo site (derived from kb/, fully rebuildable)
web/content/
web/content-internal/
web/public/
web/resources/
web/.hugo_build.lock

# local environment / secrets — never commit (.env.example is the tracked template)
.env

# local Claude Code session state
.claude/

# internal working notes — never published (folded into docs/decisions.md ADR-014)
/DECISIONS-NEEDED.md
/prophet-going-public-brief.md
/docs/dev-log.md

# macOS
.DS_Store
