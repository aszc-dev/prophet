;; Per-repo ingest config for `slayerlabs/slayer` (a Next.js app, not Hugo).
;; The knowledge lives in structured JSON under public/, not in content/*.md, so
;; the kind-table and the JSON field-mappings are source-specific. A different
;; source = a different config; downstream stages do not change.
{;; org/repo on GitHub for this source's shortname. Read-path only: the provenance
 ;; renderer (prophet.provenance) maps a `git:slayer@...` ref to a blob URL.
 ;; A source without :github -> nil URL (graceful; the raw ref still shows).
 :github "slayerlabs/slayer"

 ;; source_key / provenance-ref prefix, so keys stay stable across clone paths.
 :shortname "slayer"

 :kind-rules
 [["public/data/datasety.json"       :json]
  ["public/data/benchmarks.json"     :json]
  ["public/results/experiments.json" :json]
  ["public/results/matrix.json"      :json]
  ;; leaderboard results attach as observations to benchmark anchors
  ["public/results/leaderboard.json" :leaderboard]
  ;; narrative knowledge docs (plain markdown, no frontmatter)
  ["*.md"                            :doc]
  ["bench/*.md"                      :doc]
  ["public/data/**/*.md"             :doc]]

 ;; path -> spec. Maps each source's own field names to the canonical node shape.
 ;; `:observations` is a data-driven mapping (ADR-017): each entry carries a closed
 ;; `:kind` (:result :decision :method :config :meta :link :definition) plus an
 ;; extraction mode interpreted by extract/json. State is never set here — every
 ;; fact becomes an observation; synthesis selects State by kind salience.
 ;;   modes: {:field K [:tmpl S]}            single scalar (verbatim without :tmpl)
 ;;          {:fields [K..] :tmpl S}         several fields into one line
 ;;          {:path [K..] [:tmpl S]}         nested scalar
 ;;          {:path [K..] :each :kv [:tmpl]} map fan-out, one obs per key (src order)
 ;;          {:field K :roll :kv ...}        roll a map into one obs (sorted)
 ;;          {:path [K..] :pick :last-y}     last y of a [x y] series
 ;;          {:path [:rows] :each :row :cols-field :cols}   matrix rows
 :json-specs
 {"public/data/datasety.json"
  {:node-type :dataset
   :iter :list
   :id :id
   :title :nazwa
   :tags :tagi
   :moc ["dane"]
   :aliases [:id :nazwa]
   :observations
   [{:kind :definition :field :opis}
    {:kind :meta :field :licencja  :tmpl "licencja: %s"}
    {:kind :meta :field :rozmiar   :tmpl "rozmiar: %s"}
    {:kind :meta :field :status    :tmpl "status: %s"}
    {:kind :meta :field :kategoria :tmpl "kategoria: %s"}
    {:kind :link :field :link :tmpl "źródło: %s"}]}

  "public/data/benchmarks.json"
  {:node-type :benchmark
   :iter :list
   :id :id
   :title :nazwa
   :tags :tagi
   :moc ["ewaluacja"]
   :aliases [:id :nazwa]
   :observations
   [{:kind :definition :field :opis}
    {:kind :meta :fields [:metryka :metryka_klucz] :tmpl "metryka: %s (%s)"}
    {:kind :meta :field :rola         :tmpl "rola: %s"}
    {:kind :meta :field :typ_zadania  :tmpl "typ zadania: %s"}
    {:kind :meta :field :licencja     :tmpl "licencja: %s"}
    {:kind :meta :field :rozmiar      :tmpl "rozmiar: %s"}
    {:kind :meta :field :kategoria    :tmpl "kategoria: %s"}
    {:kind :meta :field :data_dodania :tmpl "dodano: %s"}
    {:kind :meta :field :dodal        :tmpl "dodał: %s"}
    {:kind :meta :field :status       :tmpl "status: %s"}
    {:kind :link :field :link :tmpl "źródło: %s"}]}

  "public/results/experiments.json"
  {:node-type :experiment
   :iter :dict-by-key
   :under "experiments"
   :id :id
   :title :name
   :moc ["eksperymenty"]
   :aliases [:id]
   :observations
   [{:kind :meta :field :date   :tmpl "data: %s"}
    {:kind :meta :field :status :tmpl "status: %s"}
    {:kind :meta :field :base   :tmpl "baza: %s"}
    {:kind :method :field :method :tmpl "metoda: %s"}
    {:kind :meta   :path [:eval :harness] :tmpl "harness: %s"}
    {:kind :result :path [:eval :tasks] :each :kv :tmpl "%s: %s"}
    {:kind :result :path [:eval :macro] :tmpl "macro: %s"}
    {:kind :result :path [:eval :base_macro] :tmpl "base_macro: %s"}
    {:kind :decision :path [:eval :note]}
    {:kind :decision :field :note}
    {:kind :meta   :field :log_note}
    {:kind :config :field :n_examples :tmpl "n_examples: %s"}
    {:kind :config :field :data :roll :kv :prefix "miks: " :item "%s %s" :sort :val-desc}
    {:kind :config :field :train_cfg :roll :kv :prefix "train_cfg: " :item "%s %s" :sort :key-asc}
    {:kind :config :field :early_stop :tmpl "early-stop: %s"}
    {:kind :result :path [:curves :eval] :pick :last-y :tmpl "eval-loss końcowy: %s"}
    {:kind :link :field :hf      :tmpl "HF: %s"}
    {:kind :link :field :data_hf :tmpl "HF: %s"}
    {:kind :meta :field :dataset_desc :tmpl "dataset: %s"}]}

  "public/results/matrix.json"
  {:node-type :axis
   :iter :dict-by-key
   :under "sections"
   :id :official_for
   :title :title
   :moc ["ewaluacja"]
   :aliases [:official_for]
   :observations
   [{:kind :meta :field :protocol :tmpl "protokół: %s"}
    {:kind :result :path [:rows] :each :row :cols-field :cols}
    {:kind :decision :field :note}]}}}
